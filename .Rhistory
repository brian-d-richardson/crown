# Analysis 4: Analysis Using Single Imputed Data Set
# Brian Richardson
# 2026-04-17
###############################################################################
###############################################################################
# setup -------------------------------------------------------------------
## clear workspace
rm(list = ls())
## load packages
library(dplyr)
library(tidyr)
library(mice)
library(naniar)
library(ggplot2)
library(ggh4x)
library(scales)
library(devtools)
library(xgboost)
## set working directory
setwd("C:/Users/brich/OneDrive - University of North Carolina at Chapel Hill/Desktop/CIRL/PopART")
## load functions
load_all("crown")
# load multiply imputed data sets -----------------------------------------
## multiple imputation objects
popart_mult_imp <- readRDS("Analysis/derived_data/popart_mult_imp.rds")
target_mult_imp <- readRDS("Analysis/derived_data/target_mult_imp.rds")
## select data set 1 for now
popart_imp <- mice::complete(popart_mult_imp, 1)
target_imp <- mice::complete(target_mult_imp, 1)
# define parameters for analysis ------------------------------------------
## trial data
trial_dat <- popart_imp %>%
filter(arm %in% c("C", "A")) %>%
mutate(A = ifelse(arm == "C", 0, 1),
Y = event_3,
C = censor_3,
province2 = factor(province2),
TRIPLET = factor(TRIPLET))
#with(trial_dat, table(arm, province))
## target/auxiliary data
wtQ_scaling <- sum(target_imp$btwt0) / nrow(target_imp)
target_dat <- target_imp %>%
mutate(wtQ = btwt0 / wtQ_scaling) %>%
mutate(province2 = factor(province2))
## combined data
dat <- bind_rows(
mutate(trial_dat, S = 1, R = 1, wt = 1),
mutate(target_dat, S = 0, R = 0, A = 0, C = 0, Y = 0, wt = wtQ)) %>%
select(S, R, A, C, Y, wt,
province2, male_circ, age_grp, age, edu_cat, alc_cat,
married, employed, year_part_cat, hivtest_ever)
## covariates to include
my_covariates_param <- c(
"male_circ", "age")
my_covariates_nonparam <- c(
"province2",
"male_circ",
"age",
"edu_cat",
"alc_cat",
"married",
"employed",
"year_part_cat",
"hivtest_ever")
## outcome regression formula
mu_fmla <- as.formula(paste(
"Y ~ A * province2 * (",
paste(c(my_covariates_param), collapse = " + "), ")"))
## censoring model formula
C_fmla <- as.formula(paste(
"C ~ A * province2 * (",
paste(c(my_covariates_param), collapse = " + "), ")"))
## propensity model formula
pi_fmla <- as.formula(paste(
"Q ~ province2 * (",
paste(my_covariates_param, collapse = " + "), ")"))
# analyze data ------------------------------------------------------------
## naive g-formula
gfmla_naive <- gfmla_fit_naive(
dat = filter(dat, S == 1, R ==1),
mu_fmla = mu_fmla)
## proposed g-formula
gfmla_prop <- gfmla_fit(
dat = dat,
mu_fmla = mu_fmla)
## naive IPW
ipw_naive <- ipw_fit_naive(
dat = filter(dat, S == 1, R == 1),
C_fmla = C_fmla)
## proposed IPW
ipw_prop <- ipw_fit(
dat = dat,
pi_fmla = pi_fmla)
## naive AIPW
aipw_naive <- aipw_fit_naive(
dat = filter(dat, S == 1, R == 1),
mu_fmla = mu_fmla,
C_fmla = C_fmla)
## proposed AIPW
aipw_prop <- aipw_fit(
dat = dat,
mu_fmla = mu_fmla,
pi_fmla = pi_fmla)
## proposed AIPW nonparametric sample splitting 1
set.seed(1)
aipw_nss1 <- aipw_fit_nss_v1(
dat = dat,
mu_covariates = my_covariates_nonparam,
pi_covariates = my_covariates_nonparam,
K = 50)
## proposed AIPW nonparametric sample splitting 2
set.seed(1)
aipw_nss2 <- aipw_fit_nss_v2(
dat = dat,
mu_covariates = my_covariates_nonparam,
pi_covariates = my_covariates_nonparam,
K = 50)
## make data frame with results
res <- bind_rows(
mutate(gfmla_naive$eta_results, name = "gfmla_naive"),
mutate(gfmla_prop$eta_results, name = "gfmla_prop"),
mutate(ipw_naive$eta_results, name = "ipw_naive"),
mutate(ipw_prop$eta_results, name = "ipw_prop"),
mutate(aipw_naive$eta_results, name = "aipwpar_naive"),
mutate(aipw_prop$eta_results, name = "aipwpar_prop"),
mutate(aipw_nss1$eta_results, name = "aipwnss1_prop"),
mutate(aipw_nss2$eta_results, name = "aipwnss2_prop")) %>%
separate(
name,
into = c("est", "version"),
sep = "_") %>%
mutate(
rdhat = etahat_1 - etahat_0,
rrhat = etahat_1 / etahat_0,
var_rd = cov_11 + cov_00 - 2*cov_01,
var_rr = (cov_11 / (etahat_0^2)) +
(cov_00 * (etahat_1^2) / (etahat_0^4)) -
cov_01 * 2 * etahat_1 / (etahat_0^3),
Estimator = factor(
est,
levels = c("ipw", "gfmla", "aipwpar", "aipwnss1", "aipwnss2"),
labels = c("IPW", "G-Formula", "AIPW-PAR", "AIPW-NSS1", "AIPW-NSS2")),
Version = factor(
version,
levels = c("naive", "prop"),
labels = c("Naive", "Proposed"))) %>%
select(!c(est, version))
# reshape results ---------------------------------------------------------
res <- res %>%
rename(est_eta0 = etahat_0,
est_eta1 = etahat_1,
est_rd = rdhat,
est_rr = rrhat,
var_eta0 = cov_00,
var_eta1 = cov_11) %>%
select(!cov_01) %>%
pivot_longer(
cols = matches("^(est|var)_"),
names_to = c("type", "param"),
names_sep = "_",
values_to = "value") %>%
pivot_wider(
names_from = type,
values_from = value,
id_cols = c(Version, Estimator, param)) %>%
mutate(ci_lower = est - qnorm(0.975) * sqrt(var),
ci_upper = est + qnorm(0.975) * sqrt(var),
Param = factor(param,
levels = c("eta0", "eta1", "rd", "rr"),
labels = c("eta(0)", "eta(1)",
"Risk Difference", "Risk Ratio")),
Version = factor(
Version,
levels = c("Naive", "Proposed"),
labels = c("Naive", "Proposed")))
# save and load results ---------------------------------------------------
write.csv(res, "Analysis/results/a4_results.csv", row.names = F)
res <- read.csv("Analysis/results/a4_results.csv") %>%
mutate(Estimator = factor(
Estimator,
levels = c("G-Formula", "IPW", "AIPW-PAR", "AIPW-NSS1", "AIPW-NSS2")))
# plot risks --------------------------------------------------------------
res %>%
filter(param %in% c("eta0", "eta1")) %>%
ggplot(aes(x = Param,
color = Param,
fill = Param,
y = est)) +
geom_linerange(aes(ymin = ci_lower,
ymax = ci_upper),
position = position_dodge(width = 0.4)) +
geom_point(size = 2,
position = position_dodge(width = 0.4)) +
scale_x_discrete(labels = parse_format()) +
facet_grid(Version ~ Estimator) +
labs(x = NULL,
y = "Estimate (95% CI)") +
theme_bw() +
theme(legend.position = "none")
## save image
ggsave("Analysis/results/a4_risks.png",
dpi = 300, width = 6, height = 4)
# Plot RD and RR ----------------------------------------------------------
res %>%
filter(param %in% c("rd", "rr")) %>%
